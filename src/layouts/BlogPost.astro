---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

interface Props { title: string; description: string; date: Date; tags: string[] }
const { title, description, date, tags } = Astro.props;
---
<!doctype html>
<html lang="zh-Hant">
	<head><BaseHead title={`${title}｜紫夜筆記`} description={description} type="article" date={date} tags={tags} /></head>
	<body>
		<Header />
		<main class="container article-shell">
			<article>
				<header class="article-header">
					<FormattedDate date={date} />
					<h1>{title}</h1>
					<p>{description}</p>
					<div class="tags">{tags.map((tag) => <span>#{tag}</span>)}</div>
				</header>
				<div class="prose"><slot /></div>
			</article>
		</main>
		<Footer />
	</body>
</html>
